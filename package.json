{
  "name": "ai-ppt-skills",
  "version": "1.7.6",
  "description": "HTML PPT skills for Claude CLI / Kimi CLI: preview, scaffold, edit, and generate decks from URL/article.",
  "bin": {
    "ai-ppt-skills": "./install-skills.js"
  },
  "scripts": {
    "install-skills": "node install-skills.js",
    "postinstall": "node install-skills.js",
    "upgrade-decks": "node scripts/upgrade-decks.mjs",
    "web": "node server.mjs",
    "generate": "node scripts/generate-deck.mjs",
    "export-pptx": "node scripts/export-pptx.mjs",
    "export-pptx-image": "node scripts/export-pptx.mjs --image",
    "export-pdf": "node scripts/export-pdf.mjs",
    "backup": "node scripts/backup.mjs"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^3.12.0",
    "puppeteer": "^25.3.0",
    "puppeteer-core": "^23.0.0"
  },
  "files": [
    "skills/",
    "install-skills.js",
    "install-skills.sh",
    "ai-ppt-base/",
    "web/",
    "server.mjs",
    "scripts/",
    "README.md",
    "AGENTS.md",
    "MEMORY.md"
  ],
  "keywords": [
    "ppt",
    "slides",
    "html",
    "claude-cli",
    "kimi-cli",
    "skills"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:DrDragonIsMe/ai-ppt.git"
  }
}
